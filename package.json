{
  "name": "self-improving-dual-brain",
  "version": "1.0.0",
  "private": true,
  "description": "Dual-brain memory runtime for self-improving skill (Markdown + Pinecone).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "memory:init": "node scripts/memory-cli.js init-index",
    "memory:save": "node scripts/memory-cli.js save",
    "memory:search": "node scripts/memory-cli.js search",
    "memory:forget": "node scripts/memory-cli.js forget",
    "memory:import:start": "node scripts/memory-cli.js import-start",
    "memory:import:status": "node scripts/memory-cli.js import-status",
    "memory:import:list": "node scripts/memory-cli.js import-list",
    "memory:import:cancel": "node scripts/memory-cli.js import-cancel",
    "memory:freshness": "node scripts/memory-cli.js freshness",
